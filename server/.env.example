# Core
NODE_ENV=development
PORT=4000
CLIENT_ORIGIN=http://localhost:5173
PUBLIC_API_URL=http://localhost:4000
DATABASE_URL=postgresql://messenger:messenger@127.0.0.1:5432/messenger?schema=public
JWT_SECRET=replace-with-a-random-secret-at-least-24-characters
UPLOAD_DIR=../uploads

# Redis
REDIS_URL=redis://127.0.0.1:6379

# LiveKit (required for calls, meetings, voice rooms, and screen sharing)
LIVEKIT_URL=wss://livekit.example.com
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
# LIVEKIT_SERVERS_CONFIG_PATH=./livekit-servers.json

# Apple Push Notification service
APNS_BUNDLE_ID=com.example.app
APNS_KEY_ID=
APNS_KEY_PATH=
APNS_TEAM_ID=
APNS_PRODUCTION=false

# Store subscription verification
APPLE_BUNDLE_ID=com.example.app
APPLE_SHARED_SECRET=
GOOGLE_PACKAGE_NAME=com.example.app
GOOGLE_SERVICE_ACCOUNT_PATH=
# GOOGLE_SERVICE_ACCOUNT_JSON=

# Firebase Admin / Android push
FIREBASE_SERVICE_ACCOUNT_PATH=

# Optional service policy
CATALOG_URL=
OBJECTIONABLE_CONTENT_TERMS=
SCREENSHOT_SUBSCRIPTION_BYPASS=false
SUBSCRIPTION_BYPASS_USERNAMES=

# Optional internal service-event identities
SERVER_EVENTS_GROUP_ID=
SERVER_EVENTS_INTERNAL_SECRET=
SERVER_EVENTS_LIVEKIT_ID=
SERVER_EVENTS_SUPPORT_ID=
