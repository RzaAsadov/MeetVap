{
  "name": "messenger-server",
  "version": "0.1.0",
  "private": true,
  "type": "commonjs",
  "scripts": {
    "dev": "tsx watch src/server.ts",
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "lint": "eslint \"src/**/*.ts\"",
    "prisma:generate": "node scripts/prisma-with-env.cjs generate",
    "prisma:migrate": "node scripts/prisma-with-env.cjs migrate dev",
    "prisma:deploy": "node scripts/prisma-with-env.cjs migrate deploy",
    "prisma:studio": "node scripts/prisma-with-env.cjs studio",
    "meetvap:ensure-system": "node scripts/ensure-meetvap-system-account.cjs"
  },
  "dependencies": {
    "@parse/node-apn": "^8.1.0",
    "@prisma/client": "^6.7.0",
    "bcryptjs": "^3.0.2",
    "cors": "^2.8.5",
    "dotenv": "^16.5.0",
    "express": "^4.21.2",
    "firebase-admin": "^13.8.0",
    "helmet": "^8.1.0",
    "jsonwebtoken": "^9.0.2",
    "livekit-server-sdk": "^2.15.2",
    "morgan": "^1.10.0",
    "redis": "^6.0.1",
    "socket.io": "^4.8.1",
    "zod": "^3.24.3"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.1",
    "@types/jsonwebtoken": "^9.0.9",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.15.3",
    "@typescript-eslint/eslint-plugin": "^8.31.0",
    "@typescript-eslint/parser": "^8.31.0",
    "eslint": "^8.57.1",
    "prisma": "^6.7.0",
    "tsx": "^4.19.4",
    "typescript": "^5.8.3"
  }
}
